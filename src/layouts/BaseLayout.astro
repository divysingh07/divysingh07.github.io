---
const { title = "Divyansh Singh" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}global.css`} />
  </head>

  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="#home">Divyansh Singh</a>

        <button class="menuToggle" aria-label="Menu">☰</button>

        <nav class="nav" id="topnav">
          <a href="#home" data-section="home">Home</a>
          <a href="#experience" data-section="experience">Experience</a>
          <a href="#education" data-section="education">Education</a>
          <a href="#outside" data-section="outside">Beyond the Office</a>
          <a href="#connect" data-section="connect">Connect</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
      <footer class="footer">© {new Date().getFullYear()} Divyansh Singh</footer>
    </main>

    <script is:inline>
      const sectionIds = ["home", "experience", "education", "outside", "connect"];
      const navLinks = Array.from(document.querySelectorAll('#topnav a[data-section]'));

      function setActive(id) {
        navLinks.forEach((a) => a.classList.toggle("active", a.dataset.section === id));
      }

      const sections = sectionIds
        .map((id) => document.getElementById(id))
        .filter(Boolean);

      const io = new IntersectionObserver((entries) => {
        const best = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (best?.target?.id) setActive(best.target.id);
      }, {
        root: null,
        threshold: [0.15, 0.25, 0.35, 0.5, 0.65],
        rootMargin: "-20% 0px -55% 0px"
      });

      sections.forEach((s) => io.observe(s));

      const hash = location.hash?.replace("#", "");
      if (sectionIds.includes(hash)) setActive(hash);
      else setActive("home");
    </script>

    <script is:inline>
      const btn = document.querySelector('.menuToggle');
      const nav = document.querySelector('.nav');

      if (btn && nav) {
        btn.addEventListener('click', () => {
          nav.classList.toggle('open');
        });
      }
    </script>
  </body>
</html>