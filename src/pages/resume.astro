---
const { title = "Divyansh Singh" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}global.css`} />
  </head>
  <body>
    <header class="container nav">
      <a class="brand" href={`${import.meta.env.BASE_URL}`}>Divyansh Singh</a>
      <nav class="links">
        <a href={`${import.meta.env.BASE_URL}resume`}>Resume</a>
        <a href={`${import.meta.env.BASE_URL}blog/first-post`}>Blog</a>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="container footer">
      <span>© {new Date().getFullYear()} Divyansh Singh</span>
    </footer>
  </body>
</html>